{
  "name": "hermes-webui-cyber",
  "version": "1.0.0",
  "description": "Hermes Cyberpunk WebApp — manage sessions, skills, memory, and tools",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"BACK,FRONT\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && backend/venv/bin/python -m uvicorn main:app --reload --port 23689 --host 127.0.0.1",
    "build": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "start": "bash start.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
